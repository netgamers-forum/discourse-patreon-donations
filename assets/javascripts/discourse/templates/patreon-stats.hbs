<div class="patreon-stats-page">
  <h1>{{i18n "patreon_stats.title"}}</h1>

  {{#if hasStats}}
    <div class="patreon-stats-container">
      <div class="stat-card">
        <h3>{{i18n "patreon_stats.active_subscribers"}}</h3>
        <p class="stat-value">{{patronCount}}</p>
      </div>

      <div class="stat-card">
        <h3>{{i18n "patreon_stats.monthly_estimate"}}</h3>
        <p class="stat-value">${{monthlyEstimate}}</p>
      </div>

      <div class="stat-card">
        <h3>{{i18n "patreon_stats.last_month_total"}}</h3>
        <p class="stat-value">${{lastMonthTotal}}</p>
      </div>
    </div>

    {{#if updatedAt}}
      <p class="patreon-stats-updated">
        Last updated: {{updatedAt}}
      </p>
    {{/if}}

    {{#if hasMonthlyHistory}}
      <div class="patreon-monthly-history">
        <h2>{{i18n "patreon_stats.monthly_history"}}</h2>
        <div class="monthly-history-table">
          <table>
            <thead>
              <tr>
                <th>{{i18n "patreon_stats.month"}}</th>
                <th>{{i18n "patreon_stats.patrons"}}</th>
                <th>{{i18n "patreon_stats.total_amount"}}</th>
              </tr>
            </thead>
            <tbody>
              {{#each monthlyHistory as |record|}}
                <tr>
                  <td>{{record.monthName}} {{record.year}}</td>
                  <td>{{record.patron_count}}</td>
                  <td>${{record.formattedAmount}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    {{/if}}
  {{else}}
    <div class="patreon-stats-error">
      <p>{{i18n "patreon_stats.error.fetch_failed"}}</p>
    </div>
  {{/if}}
</div>
