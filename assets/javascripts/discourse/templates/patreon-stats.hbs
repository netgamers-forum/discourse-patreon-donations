<div class="patreon-stats-page">
  <h1>{{i18n "patreon_stats.title"}}</h1>
  
  {{#if model.stats}}
    <div class="patreon-stats-container">
      <div class="stat-card">
        <h3>Active Subscribers</h3>
        <p class="stat-value">{{model.stats.patron_count}}</p>
      </div>
      
      <div class="stat-card">
        <h3>Monthly Estimate</h3>
        <p class="stat-value">${{format-number model.stats.monthly_estimate minimumFractionDigits=2 maximumFractionDigits=2}}</p>
      </div>
      
      <div class="stat-card">
        <h3>Last Month Total</h3>
        <p class="stat-value">${{format-number model.stats.last_month_total minimumFractionDigits=2 maximumFractionDigits=2}}</p>
      </div>
    </div>
    
    {{#if model.monthly_history}}
      <div class="patreon-monthly-history">
        <h2>Monthly History (Last 12 Months)</h2>
        <div class="monthly-history-table">
          <table>
            <thead>
              <tr>
                <th>Month</th>
                <th>Patrons</th>
                <th>Total Amount</th>
              </tr>
            </thead>
            <tbody>
              {{#each model.monthly_history as |record|}}
                <tr>
                  <td>{{month-name record.month}} {{record.year}}</td>
                  <td>{{record.patron_count}}</td>
                  <td>${{format-number record.total_amount minimumFractionDigits=2 maximumFractionDigits=2}}</td>
                </tr>
              {{/each}}
            </tbody>
          </table>
        </div>
      </div>
    {{/if}}
  {{else}}
    <div class="patreon-stats-error">
      <p>{{i18n "patreon_stats.error.fetch_failed"}}</p>
    </div>
  {{/if}}
</div>
