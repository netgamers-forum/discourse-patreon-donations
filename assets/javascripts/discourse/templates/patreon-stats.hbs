<div class="patreon-stats-page">
  <h1>Patreon Campaign Statistics</h1>
  
  {{! Debug output }}
  <div style="background: yellow; padding: 10px; margin: 10px 0;">
    <strong>Debug:</strong><br>
    model.stats = {{model.stats}}<br>
    patron_count = {{model.stats.patron_count}}<br>
    monthly_estimate = {{model.stats.monthly_estimate}}<br>
  </div>
  
  {{#if model.error}}
    <div class="patreon-stats-error">
      <p class="error-message">⚠️ {{model.message}}</p>
      <p>Please check the Discourse logs for more details or contact an administrator.</p>
    </div>
  {{/if}}
  
  {{#if model.stats}}
    <div class="patreon-stats-container">
      <div class="stat-card">
        <h3>Active Subscribers</h3>
        <p class="stat-value">{{model.stats.patron_count}}</p>
      </div>
      
      <div class="stat-card">
        <h3>Monthly Estimate</h3>
        <p class="stat-value">${{model.stats.monthly_estimate}}</p>
      </div>
      
      <div class="stat-card">
        <h3>Last Month Total</h3>
        <p class="stat-value">${{model.stats.last_month_total}}</p>
      </div>
    </div>
    
    <div class="patreon-breakdown">
      <h3>Revenue Breakdown</h3>
      <div class="breakdown-content">
        <p class="breakdown-note">Understanding the actual income available for expenses:</p>
        <div class="breakdown-table">
          <div class="breakdown-row">
            <span class="breakdown-label">Gross monthly revenue:</span>
            <span class="breakdown-value">${{model.stats.monthly_estimate}}</span>
          </div>
          <div class="breakdown-row deduction">
            <span class="breakdown-label">Less Patreon fee (10%):</span>
            <span class="breakdown-value">-${{multiply model.stats.monthly_estimate 0.10}}</span>
          </div>
          <div class="breakdown-row subtotal">
            <span class="breakdown-label">Subtotal after Patreon:</span>
            <span class="breakdown-value">${{multiply model.stats.monthly_estimate 0.90}}</span>
          </div>
          <div class="breakdown-row deduction">
            <span class="breakdown-label">Less taxes (43%):</span>
            <span class="breakdown-value">-${{multiply (multiply model.stats.monthly_estimate 0.90) 0.43}}</span>
          </div>
          <div class="breakdown-row total">
            <span class="breakdown-label">Net income available (57%):</span>
            <span class="breakdown-value">${{multiply (multiply model.stats.monthly_estimate 0.90) 0.57}}</span>
          </div>
        </div>
      </div>
    </div>
    
    {{#if model.monthly_history}}
      <div class="patreon-monthly-history">
        <h2>Monthly History (Last 12 Months)</h2>
        {{#if model.monthly_history.length}}
          <div class="monthly-history-table">
            <table>
              <thead>
                <tr>
                  <th>Month</th>
                  <th>Patrons</th>
                  <th>Total Amount</th>
                </tr>
              </thead>
              <tbody>
                {{#each model.monthly_history as |record|}}
                  <tr>
                    <td>{{month-name record.month}} {{record.year}}</td>
                    <td>{{record.patron_count}}</td>
                    <td>${{record.total_amount}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <div class="no-history-message">
            <p>No historical data available yet. Monthly snapshots will accumulate over time as the sync job runs.</p>
            <p>Historical data is created automatically at the beginning of each month.</p>
          </div>
        {{/if}}
      </div>
    {{/if}}
  {{else}}
    <div class="patreon-stats-error">
      <p>No stats data available</p>
    </div>
  {{/if}}
</div>
