<div class="patreon-stats-page">
  <h1>Patreon Donation Summary</h1>

  {{#if model.error}}
    <div class="patreon-stats-error">
      <p class="error-message">⚠️ {{model.message}}</p>
      <p>Please check the Discourse logs for more details or contact an administrator.</p>
    </div>
  {{/if}}

  {{#if model.stats}}
    <div class="patreon-stats-grid">
      <div class="stat-card">
        <h3>Current Active Patrons</h3>
        <p class="stat-value">{{model.stats.patron_count}}</p>
      </div>

      <div class="stat-card">
        <h3>Patron Changes</h3>
        <p class="stat-value">{{{format-patron-change model.stats.patrons_joined model.stats.patrons_left}}}</p>
      </div>

      <div class="stat-card">
        <span class="patreon-info-tooltip">{{d-icon "circle-info"}}<span class="patreon-tooltip-content">This is an estimate based on the pledge amounts of active patrons. Patreon does not expose actual transaction data via its API, so if any payments are declined or fail, the actual amount received will be lower.</span></span>
        <h3>Next Month Estimate</h3>
        <p class="stat-value">{{model.stats.currency}} {{multiply model.stats.monthly_estimate 1}}</p>
      </div>

      <div class="stat-card">
        <h3>Change from Last Month</h3>
        <p class="stat-value">{{{format-change model.stats.monthly_change}}}</p>
      </div>
    </div>

    <div class="patreon-breakdown">
      <h3>Revenue Breakdown</h3>
      <div class="breakdown-content">
        <p class="breakdown-note">Understanding the actual income available for expenses:</p>
        <div class="breakdown-table">
          <div class="breakdown-row">
            <span class="breakdown-label">Estimated next month revenue:</span>
            <span class="breakdown-value">{{model.stats.currency}} {{multiply model.stats.monthly_estimate 1}}</span>
          </div>
          <div class="breakdown-row deduction">
            <span class="breakdown-label">Less Patreon fee ({{siteSettings.patreon_donations_platform_fee_percentage}}%):</span>
            <span class="breakdown-value">-{{model.stats.currency}} {{multiply model.stats.monthly_estimate (divide siteSettings.patreon_donations_platform_fee_percentage 100)}}</span>
          </div>
          <div class="breakdown-row subtotal">
            <span class="breakdown-label">Subtotal after Patreon:</span>
            <span class="breakdown-value">{{model.stats.currency}} {{multiply model.stats.monthly_estimate (subtract 1 (divide siteSettings.patreon_donations_platform_fee_percentage 100))}}</span>
          </div>
          <div class="breakdown-row deduction">
            <span class="breakdown-label">Less taxes ({{siteSettings.patreon_donations_tax_rate_percentage}}%):</span>
            <span class="breakdown-value">-{{model.stats.currency}} {{multiply (multiply model.stats.monthly_estimate (subtract 1 (divide siteSettings.patreon_donations_platform_fee_percentage 100))) (divide siteSettings.patreon_donations_tax_rate_percentage 100)}}</span>
          </div>
          <div class="breakdown-row total">
            <span class="breakdown-label">Net income available ({{subtract 100 siteSettings.patreon_donations_tax_rate_percentage}}%):</span>
            <span class="breakdown-value">{{model.stats.currency}} {{multiply (multiply model.stats.monthly_estimate (subtract 1 (divide siteSettings.patreon_donations_platform_fee_percentage 100))) (subtract 1 (divide siteSettings.patreon_donations_tax_rate_percentage 100))}}</span>
          </div>
        </div>
        {{#if model.stats.recently_declined_count}}
          <p class="breakdown-declined-note">{{d-icon "circle-exclamation"}} {{model.stats.recently_declined_count}} declined payment(s) in the last 25 days, totalling {{model.stats.currency}} {{multiply model.stats.recently_declined_amount 1}} in potentially lost revenue.</p>
        {{/if}}
      </div>
    </div>

    {{#if model.monthly_history}}
      <div class="patreon-monthly-history">
        <h2>Monthly History (Last 12 Months)</h2>
        {{#if model.monthly_history.length}}
          <div class="monthly-history-table">
            <table>
              <thead>
                <tr>
                  <th>Month</th>
                  <th>Patrons</th>
                  <th>Changes</th>
                  <th>Declined</th>
                  <th>Est. Amount</th>
                  <th>Est. Net</th>
                </tr>
              </thead>
              <tbody>
                {{#each model.monthly_history as |record|}}
                  <tr>
                    <td>{{#if record.snapshot_taken_at}}<span class="snapshot-time-tooltip">{{d-icon "clock"}}<span class="snapshot-time-content">Snapshot taken: {{format-datetime record.snapshot_taken_at}}</span></span> {{/if}}{{month-name record.month}} {{record.year}}</td>
                    <td>{{record.patron_count}}</td>
                    <td>{{{format-patron-change record.patrons_joined record.patrons_left}}}</td>
                    <td>{{#if record.declined_count}}<span class="change-negative">{{record.declined_count}}</span>{{else}}0{{/if}}</td>
                    <td>{{model.stats.currency}} {{multiply record.total_amount 1}}</td>
                    <td>{{#if record.net_amount}}{{model.stats.currency}} {{multiply record.net_amount 1}}{{else}}N/A{{/if}}</td>
                  </tr>
                {{/each}}
              </tbody>
            </table>
          </div>
        {{else}}
          <div class="no-history-message">
            <p>No historical data available yet. Monthly snapshots will accumulate over time as the sync job runs.</p>
            <p>Historical data is created automatically at the beginning of each month.</p>
          </div>
        {{/if}}
      </div>
    {{/if}}
  {{else}}
    <div class="patreon-stats-error">
      <p>No stats data available</p>
    </div>
  {{/if}}

  <div class="patreon-stats-footer">
    <a href="https://github.com/netgamers-forum/discourse-patreon-donations" target="_blank" rel="noopener noreferrer">{{d-icon "fab-github"}}</a>
  </div>
</div>
