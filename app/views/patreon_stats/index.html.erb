<div class="patreon-stats-page container">
  <h1><%= t('patreon_stats.title') %></h1>
  
  <div id="patreon-stats-container">
    <p>Loading Patreon statistics...</p>
  </div>
</div>

<script>
(function() {
  fetch('/patreon-stats.json')
    .then(response => response.json())
    .then(data => {
      const html = `
        <div class="patreon-stats-grid">
          <div class="stat-card">
            <h3>Active Subscribers</h3>
            <p class="stat-value">${data.stats.patron_count || 0}</p>
          </div>
          <div class="stat-card">
            <h3>Monthly Estimate</h3>
            <p class="stat-value">$${(data.stats.monthly_estimate || 0).toFixed(2)}</p>
          </div>
          <div class="stat-card">
            <h3>Last Month Total</h3>
            <p class="stat-value">$${(data.stats.last_month_total || 0).toFixed(2)}</p>
          </div>
        </div>
        
        ${data.monthly_history && data.monthly_history.length > 0 ? `
          <div class="monthly-history">
            <h2>Monthly History (Last 12 Months)</h2>
            <table>
              <thead>
                <tr>
                  <th>Month</th>
                  <th>Patrons</th>
                  <th>Total Amount</th>
                </tr>
              </thead>
              <tbody>
                ${data.monthly_history.map(record => `
                  <tr>
                    <td>${getMonthName(record.month)} ${record.year}</td>
                    <td>${record.patron_count}</td>
                    <td>$${record.total_amount.toFixed(2)}</td>
                  </tr>
                `).join('')}
              </tbody>
            </table>
          </div>
        ` : ''}
      `;
      
      document.getElementById('patreon-stats-container').innerHTML = html;
    })
    .catch(error => {
      document.getElementById('patreon-stats-container').innerHTML = 
        '<p class="error">Unable to load Patreon statistics. Please try again later.</p>';
      console.error('Error loading Patreon stats:', error);
    });
  
  function getMonthName(month) {
    const months = ['January', 'February', 'March', 'April', 'May', 'June',
                   'July', 'August', 'September', 'October', 'November', 'December'];
    return months[month - 1] || '';
  }
})();
</script>

<style>
.patreon-stats-page {
  max-width: 1000px;
  margin: 2rem auto;
  padding: 2rem;
}

.patreon-stats-grid {
  display: grid;
  grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
  gap: 2rem;
  margin: 2rem 0;
}

.stat-card {
  background: #f4f4f4;
  border: 1px solid #ddd;
  border-radius: 8px;
  padding: 2rem;
  text-align: center;
}

.stat-card h3 {
  margin: 0 0 1rem 0;
  font-size: 1rem;
  font-weight: 600;
  text-transform: uppercase;
  color: #666;
}

.stat-card .stat-value {
  margin: 0;
  font-size: 2.5rem;
  font-weight: 700;
  color: #333;
}

.monthly-history {
  margin-top: 3rem;
}

.monthly-history table {
  width: 100%;
  border-collapse: collapse;
  background: #fff;
  border: 1px solid #ddd;
}

.monthly-history th,
.monthly-history td {
  padding: 1rem;
  text-align: left;
  border-bottom: 1px solid #ddd;
}

.monthly-history th {
  background: #f4f4f4;
  font-weight: 600;
}

.monthly-history tr:hover {
  background: #f9f9f9;
}

.error {
  color: #d00;
  text-align: center;
  padding: 2rem;
  background: #fee;
  border: 1px solid #fcc;
  border-radius: 8px;
}
</style>
